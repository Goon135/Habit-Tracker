# Telegram
BOT_TOKEN=123456:ABC-your-token-from-BotFather

# Postgres
DATABASE_URL=postgresql+asyncpg://habitbot:habitbot@localhost:5432/habitbot

# Ollama (локальный LLM — для AI-коуча и извлечения привычек)
# По умолчанию работает на localhost:11434. Менять обычно не нужно.
OLLAMA_HOST=http://localhost:11434
# Модель: llama3.1:8b (нужно 5 ГБ VRAM на GPU или 8 ГБ RAM на CPU).
# Альтернативы для слабого железа: llama3.2:3b (~2 ГБ) или qwen2.5:7b (~5 ГБ).
OLLAMA_MODEL=llama3.1:8b

# Whisper (локально)
# tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=small
# cpu | cuda
WHISPER_DEVICE=cpu
# int8 | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=int8

LOG_LEVEL=INFO
